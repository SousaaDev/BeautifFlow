// Arquivo de exemplo de requests para testar a API
// Use com Thunder Client, Postman ou Insomnia

// ==========================================
// 🚀 1. CRIAR UMA BARBEARIA (TENANT)
// ==========================================
POST http://localhost:3000/api/tenants
Content-Type: application/json

{
  "name": "Barbearia do João",
  "slug": "barbearia-joao",
  "businessHours": {
    "mon": "09:00-19:00",
    "tue": "09:00-19:00",
    "wed": "09:00-19:00",
    "thu": "09:00-19:00",
    "fri": "09:00-19:00",
    "sat": "08:00-17:00",
    "sun": "closed"
  }
}

// ==========================================
// 📋 2. LISTAR TODAS AS BARBEARIAS
// ==========================================
GET http://localhost:3000/api/tenants

// ==========================================
// 🔍 3. BUSCAR BARBEARIA POR ID
// ==========================================
GET http://localhost:3000/api/tenants/{id}

// ==========================================
// 🔐 4. LOGIN (quando implementar)
// ==========================================
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "email": "admin@barbearia-joao.com",
  "password": "senha123"
}

// ==========================================
// 📝 5. CRIAR CLIENTE (quando implementar)
// ==========================================
POST http://localhost:3000/api/customers
Authorization: Bearer {token}
Content-Type: application/json

{
  "name": "João Silva",
  "phone": "+5511999999999",
  "email": "joao@email.com"
}